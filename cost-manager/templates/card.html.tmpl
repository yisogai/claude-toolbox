<!doctype html>
<!--
  凍結: これは pillow 版の失敗時フォールバック専用の簡易版テンプレート。
  task_desc 表示・Fable/その他小計・Retina(2x) 対応等の新機能は
  scripts/render_image.py の render_pillow() のみに実装している（正はそちら）。
-->
<html lang="ja">
<head>
<meta charset="utf-8">
<title>コストレポートカード</title>
<style>
  html, body {
    margin: 0;
    padding: 0;
    width: ${card_width}px;
    height: ${card_height}px;
    background: #0f1115;
    font-family: "Hiragino Sans", "ヒラギノ角ゴシック", "Hiragino Kaku Gothic ProN",
                 "Noto Sans CJK JP", "Yu Gothic", sans-serif;
    color: #f2f2f2;
  }
  .card {
    box-sizing: border-box;
    width: ${card_width}px;
    height: ${card_height}px;
    padding: 36px 44px;
    background: linear-gradient(160deg, #14161d 0%, #1b1e27 100%);
    display: flex;
    flex-direction: column;
  }
  .header {
    border-bottom: 1px solid #333744;
    padding-bottom: 18px;
    margin-bottom: 20px;
  }
  .task-name {
    font-size: 30px;
    font-weight: 700;
    margin: 0 0 8px 0;
  }
  .meta {
    font-size: 16px;
    color: #a6acbd;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
    margin-bottom: 22px;
  }
  th, td {
    text-align: right;
    padding: 6px 8px;
    border-bottom: 1px solid #262a35;
  }
  th:first-child, td:first-child {
    text-align: left;
  }
  th {
    color: #8a90a3;
    font-weight: 500;
    font-size: 13px;
  }
  .total-block {
    text-align: right;
    margin-top: auto;
    padding-top: 10px;
  }
  .total-usd {
    font-size: 54px;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
  }
  .total-jpy {
    font-size: 22px;
    color: #a6acbd;
    margin-top: 4px;
  }
  .footer {
    text-align: right;
    padding-top: 12px;
    font-size: 11px;
    color: #5b6070;
  }
</style>
</head>
<body>
  <div class="card">
    <div class="header">
      <p class="task-name">${task_name}</p>
      <p class="meta">${date_jst}（JST） ${start_jst} 〜 ${end_jst}（実働 ${duration}）</p>
    </div>
    <table>
      <thead>
        <tr><th>モデル</th><th>入力</th><th>C書込</th><th>C読取</th><th>出力</th><th>料金(USD)</th></tr>
      </thead>
      <tbody>
${model_rows_html}
      </tbody>
    </table>
    <div class="total-block">
      <div class="total-usd">$$${total_usd}</div>
      <div class="total-jpy">¥${total_jpy}（1 USD = ${usd_jpy} 円）</div>
    </div>
    <div class="footer">単価 as_of: ${pricing_as_of}${stale_note}</div>
  </div>
</body>
</html>
